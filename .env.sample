APP_ID=
DISCORD_TOKEN=
PUBLIC_KEY=
OCR_SPACE_KEY=
# Required for /register, /profile, and /club leaderboard features.
# Create at uma.moe while logged in (API key page). Format: uma_k_...
UMA_API_KEY=

# Optional comma-separated guild IDs with premium leaderboard refresh (5-minute top-100 updates).
PREMIUM_GUILD_IDS=

# Bot owner Discord user ID(s) for /club setpremium and /refreshcache.
BOT_OWNER_ID=
# Optional comma-separated owner IDs (overrides/extends BOT_OWNER_ID when set).
# BOT_OWNER_IDS=
# Guild where owner-only commands (/signup, /gamba event, /gambacoin award) appear.
# BOT_OWNER_GUILD_ID=

# Optional: sync quiz settings/category files from GitHub (no manual git pull needed on host).
# If enabled, quiz JSON files are refreshed locally on this interval.
QUIZ_REMOTE_SYNC_ENABLED=false
QUIZ_REMOTE_SYNC_INTERVAL_MS=300000
QUIZ_REMOTE_REPO=JustWastingTime/TazunaDiscordBot
QUIZ_REMOTE_BRANCH=main
# Optional GitHub token for private repos / higher API rate limits.
QUIZ_REMOTE_TOKEN=